{
  "name": "safari-client",
  "version": "0.2.3",
  "description": "Desktop client for Safari Fotosub-style competitions (scheda concorrente).",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
