{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Safari Client",
  "version": "0.3.0",
  "identifier": "com.maxdrift.safari-client",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Safari Client",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU4NTdGMjFGQjQyNkUxNUYKUldSZjRTYTBIL0pYNkJFSjlndENxaWZ4QTlNcVhnZjc0N05XQ3gwYlU0MExxcjRwQWNleXROVUoK",
      "endpoints": [
        "https://github.com/maxdrift/safari-client-tauri/releases/latest/download/latest.json"
      ]
    }
  }
}
